<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Cognifyz | Student Registration</title>

  <!-- Bootstrap 5 -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <!-- Bootstrap Icons -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet"/>

  <style>
    :root {
      --primary: #667eea;
      --secondary: #764ba2;
      --success-green: #11998e;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }

    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f0f2f5;
    }

    /* ── NAVBAR ── */
    .navbar {
      background: linear-gradient(135deg, var(--primary), var(--secondary)) !important;
      box-shadow: 0 4px 15px rgba(102,126,234,0.4);
      padding: 14px 0;
    }
    .navbar-brand {
      font-size: 1.4rem;
      font-weight: 700;
      color: white !important;
      letter-spacing: 1px;
    }
    .nav-link { color: rgba(255,255,255,0.85) !important; font-weight: 500; }
    .nav-link:hover { color: white !important; }

    /* ── HERO SECTION ── */
    .hero {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      padding: 70px 0 90px;
      position: relative;
      overflow: hidden;
    }
    .hero::after {
      content: '';
      position: absolute;
      bottom: -2px;
      left: 0;
      right: 0;
      height: 60px;
      background: #f0f2f5;
      clip-path: ellipse(55% 100% at 50% 100%);
    }
    .hero h1 {
      font-size: 2.8rem;
      font-weight: 800;
      animation: fadeInDown 0.8s ease;
    }
    .hero p {
      font-size: 1.1rem;
      opacity: 0.9;
      animation: fadeInUp 0.8s ease 0.2s both;
    }
    .hero-badge {
      display: inline-block;
      background: rgba(255,255,255,0.2);
      border: 1px solid rgba(255,255,255,0.4);
      border-radius: 50px;
      padding: 6px 18px;
      font-size: 0.85rem;
      margin-bottom: 16px;
      animation: fadeIn 0.8s ease;
    }

    /* ── STATS CARDS ── */
    .stats-section { margin-top: -40px; position: relative; z-index: 10; }
    .stat-card {
      background: white;
      border-radius: 14px;
      padding: 22px;
      text-align: center;
      box-shadow: 0 8px 25px rgba(0,0,0,0.1);
      transition: transform 0.3s ease, box-shadow 0.3s ease;
      animation: fadeInUp 0.6s ease both;
    }
    .stat-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.15); }
    .stat-card .icon {
      font-size: 2rem;
      margin-bottom: 8px;
    }
    .stat-card h3 { font-size: 1.8rem; font-weight: 700; color: var(--primary); }
    .stat-card p  { color: #888; font-size: 0.9rem; margin: 0; }

    /* ── MAIN FORM CARD ── */
    .form-section { padding: 50px 0; }
    .form-card {
      background: white;
      border-radius: 18px;
      box-shadow: 0 10px 40px rgba(0,0,0,0.1);
      overflow: hidden;
      animation: fadeInUp 0.7s ease 0.3s both;
    }
    .form-header {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      padding: 28px 35px;
    }
    .form-header h2 { font-weight: 700; margin: 0; }
    .form-header p  { opacity: 0.85; margin: 5px 0 0; font-size: 0.92rem; }
    .form-body { padding: 35px; }

    .form-label { font-weight: 600; color: #555; font-size: 0.88rem; margin-bottom: 5px; }
    .form-control, .form-select {
      border: 2px solid #e8e8e8;
      border-radius: 10px;
      padding: 11px 14px;
      font-size: 0.95rem;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .form-control:focus, .form-select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(102,126,234,0.15);
    }
    .form-control.is-invalid { border-color: #dc3545; }
    .form-control.is-valid   { border-color: #22c55e; }

    .field-err { color: #dc3545; font-size: 0.8rem; margin-top: 3px; display: none; }

    /* Gender radio buttons */
    .gender-group { display: flex; gap: 15px; flex-wrap: wrap; }
    .gender-btn input { display: none; }
    .gender-btn label {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 10px 20px;
      border: 2px solid #e8e8e8;
      border-radius: 10px;
      cursor: pointer;
      font-size: 0.92rem;
      transition: all 0.25s;
      font-weight: 500;
    }
    .gender-btn input:checked + label {
      border-color: var(--primary);
      background: rgba(102,126,234,0.08);
      color: var(--primary);
    }

    .btn-submit {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      border: none;
      border-radius: 10px;
      padding: 14px;
      font-size: 1rem;
      font-weight: 600;
      width: 100%;
      transition: opacity 0.3s, transform 0.2s;
      margin-top: 8px;
    }
    .btn-submit:hover { opacity: 0.92; transform: translateY(-1px); color: white; }

    /* Server error alert */
    .server-errors {
      background: #fff0f0;
      border: 1px solid #ffcccc;
      border-radius: 10px;
      padding: 15px 18px;
      margin-bottom: 22px;
    }
    .server-errors p { color: #cc0000; font-size: 0.87rem; margin: 3px 0; }

    /* ── FEATURES SECTION ── */
    .features { padding: 60px 0; background: white; }
    .feature-card {
      text-align: center;
      padding: 30px 20px;
      border-radius: 14px;
      transition: transform 0.3s, box-shadow 0.3s;
    }
    .feature-card:hover { transform: translateY(-6px); box-shadow: 0 12px 30px rgba(0,0,0,0.1); }
    .feature-icon {
      width: 65px; height: 65px;
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.8rem;
      margin: 0 auto 18px;
    }
    .feature-card h5 { font-weight: 700; color: #333; margin-bottom: 8px; }
    .feature-card p  { color: #888; font-size: 0.9rem; }

    /* ── FOOTER ── */
    footer {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: white;
      text-align: center;
      padding: 25px;
      font-size: 0.9rem;
      opacity: 0.95;
    }

    /* ── ANIMATIONS ── */
    @keyframes fadeInDown {
      from { opacity: 0; transform: translateY(-30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeInUp {
      from { opacity: 0; transform: translateY(30px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    @keyframes fadeIn {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* ── RESPONSIVE TWEAKS ── */
    @media (max-width: 576px) {
      .hero h1 { font-size: 1.9rem; }
      .form-body { padding: 22px; }
      .form-header { padding: 20px 22px; }
    }
  </style>
</head>
<body>

<!-- NAVBAR -->
<nav class="navbar navbar-expand-lg">
  <div class="container">
    <a class="navbar-brand" href="/"><i class="bi bi-mortarboard-fill me-2"></i>Cognifyz Academy</a>
    <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
      <span style="color:white; font-size:1.4rem;"><i class="bi bi-list"></i></span>
    </button>
    <div class="collapse navbar-collapse" id="navMenu">
      <ul class="navbar-nav ms-auto">
        <li class="nav-item"><a class="nav-link" href="/"><i class="bi bi-house me-1"></i>Home</a></li>
        <li class="nav-item"><a class="nav-link" href="/students"><i class="bi bi-people me-1"></i>All Students</a></li>
      </ul>
    </div>
  </div>
</nav>

<!-- HERO -->
<section class="hero text-center">
  <div class="container">
    <div class="hero-badge"><i class="bi bi-stars me-1"></i> Full Stack Internship — Task 3</div>
    <h1>🎓 Student Registration Portal</h1>
    <p>Advanced CSS Styling & Responsive Design using Bootstrap 5</p>
  </div>
</section>

<!-- STATS -->
<section class="stats-section">
  <div class="container">
    <div class="row g-4">
      <div class="col-6 col-md-3">
        <div class="stat-card" style="animation-delay:0.1s">
          <div class="icon">👨‍🎓</div>
          <h3><%= students.length %></h3>
          <p>Registered</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card" style="animation-delay:0.2s">
          <div class="icon">📚</div>
          <h3>5</h3>
          <p>Courses</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card" style="animation-delay:0.3s">
          <div class="icon">✅</div>
          <h3>2x</h3>
          <p>Validation</p>
        </div>
      </div>
      <div class="col-6 col-md-3">
        <div class="stat-card" style="animation-delay:0.4s">
          <div class="icon">📱</div>
          <h3>100%</h3>
          <p>Responsive</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- REGISTRATION FORM -->
<section class="form-section">
  <div class="container">
    <div class="row justify-content-center">
      <div class="col-12 col-lg-8">
        <div class="form-card">
          <div class="form-header">
            <h2><i class="bi bi-person-plus-fill me-2"></i>Register Now</h2>
            <p>Fill in your details below — all fields are required</p>
          </div>
          <div class="form-body">

            <!-- Server-side errors -->
            <% if (errors && errors.length > 0) { %>
              <div class="server-errors">
                <% errors.forEach(e => { %><p><i class="bi bi-exclamation-triangle-fill me-1"></i><%= e %></p><% }) %>
              </div>
            <% } %>

            <form id="regForm" action="/register" method="POST" novalidate>
              <div class="row g-3">

                <!-- Name -->
                <div class="col-12">
                  <label class="form-label">Full Name</label>
                  <input type="text" class="form-control" id="name" name="name"
                    placeholder="e.g. Arun Kumar"
                    value="<%= old && old.name ? old.name : '' %>"/>
                  <div class="field-err" id="nameErr">Name must be at least 3 letters only.</div>
                </div>

                <!-- Email -->
                <div class="col-12 col-md-6">
                  <label class="form-label">Email Address</label>
                  <input type="email" class="form-control" id="email" name="email"
                    placeholder="e.g. arun@email.com"
                    value="<%= old && old.email ? old.email : '' %>"/>
                  <div class="field-err" id="emailErr">Enter a valid email address.</div>
                </div>

                <!-- Phone -->
                <div class="col-12 col-md-6">
                  <label class="form-label">Phone Number</label>
                  <input type="text" class="form-control" id="phone" name="phone"
                    placeholder="10-digit number" maxlength="10"
                    value="<%= old && old.phone ? old.phone : '' %>"/>
                  <div class="field-err" id="phoneErr">Enter a valid 10-digit number.</div>
                </div>

                <!-- Age + DOB -->
                <div class="col-6 col-md-3">
                  <label class="form-label">Age</label>
                  <input type="number" class="form-control" id="age" name="age"
                    placeholder="15–60" min="15" max="60"
                    value="<%= old && old.age ? old.age : '' %>"/>
                  <div class="field-err" id="ageErr">Age must be 15–60.</div>
                </div>
                <div class="col-6 col-md-5">
                  <label class="form-label">Date of Birth</label>
                  <input type="date" class="form-control" id="dob" name="dob"
                    value="<%= old && old.dob ? old.dob : '' %>"/>
                  <div class="field-err" id="dobErr">Please select your DOB.</div>
                </div>

                <!-- Course -->
                <div class="col-12 col-md-4">
                  <label class="form-label">Course</label>
                  <select class="form-select" id="course" name="course">
                    <option value="" disabled <%= !old || !old.course ? 'selected' : '' %>>Select course</option>
                    <option value="B.Tech - Computer Science"       <%= old && old.course==='B.Tech - Computer Science'       ?'selected':'' %>>B.Tech - CS</option>
                    <option value="B.Tech - Information Technology" <%= old && old.course==='B.Tech - Information Technology' ?'selected':'' %>>B.Tech - IT</option>
                    <option value="B.Sc - Data Science"             <%= old && old.course==='B.Sc - Data Science'             ?'selected':'' %>>B.Sc - DS</option>
                    <option value="MBA - Technology Management"     <%= old && old.course==='MBA - Technology Management'     ?'selected':'' %>>MBA - Tech</option>
                    <option value="MCA"                             <%= old && old.course==='MCA'                             ?'selected':'' %>>MCA</option>
                  </select>
                  <div class="field-err" id="courseErr">Please select a course.</div>
                </div>

                <!-- Gender -->
                <div class="col-12">
                  <label class="form-label">Gender</label>
                  <div class="gender-group">
                    <div class="gender-btn">
                      <input type="radio" id="male" name="gender" value="Male" <%= old && old.gender==='Male' ?'checked':'' %>>
                      <label for="male"><i class="bi bi-person"></i> Male</label>
                    </div>
                    <div class="gender-btn">
                      <input type="radio" id="female" name="gender" value="Female" <%= old && old.gender==='Female' ?'checked':'' %>>
                      <label for="female"><i class="bi bi-person"></i> Female</label>
                    </div>
                    <div class="gender-btn">
                      <input type="radio" id="other" name="gender" value="Other" <%= old && old.gender==='Other' ?'checked':'' %>>
                      <label for="other"><i class="bi bi-person"></i> Other</label>
                    </div>
                  </div>
                  <div class="field-err" id="genderErr">Please select a gender.</div>
                </div>

                <!-- Submit -->
                <div class="col-12">
                  <button type="submit" class="btn btn-submit">
                    <i class="bi bi-send-fill me-2"></i>Register Now
                  </button>
                </div>

              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FEATURES SECTION -->
<section class="features">
  <div class="container">
    <h2 class="text-center fw-bold mb-2" style="color:#4a00e0">Why Cognifyz Academy?</h2>
    <p class="text-center text-muted mb-5">Everything you need to grow as a developer</p>
    <div class="row g-4">
      <div class="col-12 col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#ede9fe"><span>🚀</span></div>
          <h5>Hands-on Projects</h5>
          <p>Work on real-world full stack projects that build your portfolio and skills.</p>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#dcfce7"><span>🏆</span></div>
          <h5>Internship Certificate</h5>
          <p>Earn a verified certificate upon completing all tasks successfully.</p>
        </div>
      </div>
      <div class="col-12 col-md-4">
        <div class="feature-card">
          <div class="feature-icon" style="background:#fef9c3"><span>💡</span></div>
          <h5>Mentorship Support</h5>
          <p>Get guidance from experienced developers throughout your journey.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- FOOTER -->
<footer>
  <p><i class="bi bi-mortarboard-fill me-2"></i>Cognifyz Technologies &copy; 2025 — Full Stack Development Internship</p>
  <p style="opacity:0.7; font-size:0.8rem; margin-top:5px;">Task 3: Advanced CSS Styling & Responsive Design</p>
</footer>

<!-- Bootstrap JS -->
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
  // Client-side validation
  function showErr(id, show) { document.getElementById(id).style.display = show ? 'block' : 'none'; }
  function mark(el, valid) {
    el.classList.toggle('is-valid', valid);
    el.classList.toggle('is-invalid', !valid);
  }

  const nameEl   = document.getElementById('name');
  const emailEl  = document.getElementById('email');
  const phoneEl  = document.getElementById('phone');
  const ageEl    = document.getElementById('age');
  const dobEl    = document.getElementById('dob');
  const courseEl = document.getElementById('course');

  nameEl.addEventListener('input',  () => { const ok=/^[a-zA-Z\s]{3,}$/.test(nameEl.value.trim()); mark(nameEl,ok); showErr('nameErr',!ok); });
  emailEl.addEventListener('input', () => { const ok=/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value); mark(emailEl,ok); showErr('emailErr',!ok); });
  phoneEl.addEventListener('input', () => { phoneEl.value=phoneEl.value.replace(/\D/g,''); const ok=/^\d{10}$/.test(phoneEl.value); mark(phoneEl,ok); showErr('phoneErr',!ok); });
  ageEl.addEventListener('input',   () => { const v=parseInt(ageEl.value),ok=v>=15&&v<=60; mark(ageEl,ok); showErr('ageErr',!ok); });
  dobEl.addEventListener('change',  () => { const ok=dobEl.value!==''; mark(dobEl,ok); showErr('dobErr',!ok); });
  courseEl.addEventListener('change',()=> { const ok=courseEl.value!==''; mark(courseEl,ok); showErr('courseErr',!ok); });

  document.getElementById('regForm').addEventListener('submit', e => {
    let valid = true;
    if (!/^[a-zA-Z\s]{3,}$/.test(nameEl.value.trim()))     { showErr('nameErr',true);   mark(nameEl,false);   valid=false; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value)) { showErr('emailErr',true);  mark(emailEl,false);  valid=false; }
    if (!/^\d{10}$/.test(phoneEl.value))                    { showErr('phoneErr',true);  mark(phoneEl,false);  valid=false; }
    const age=parseInt(ageEl.value);
    if (!age||age<15||age>60)                               { showErr('ageErr',true);    mark(ageEl,false);    valid=false; }
    if (!dobEl.value)                                       { showErr('dobErr',true);    mark(dobEl,false);    valid=false; }
    if (!document.querySelector('input[name="gender"]:checked')) { showErr('genderErr',true); valid=false; }
    else showErr('genderErr',false);
    if (!courseEl.value)                                    { showErr('courseErr',true); mark(courseEl,false); valid=false; }
    if (!valid) e.preventDefault();
  });
</script>
</body>
</html>
