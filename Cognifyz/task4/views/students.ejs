<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>All Students | Cognifyz</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet"/>
  <style>
    :root { --primary:#667eea; --secondary:#764ba2; }
    body { font-family:'Segoe UI',sans-serif; background:#f0f2f5; }
    .navbar { background:linear-gradient(135deg,var(--primary),var(--secondary)) !important; }
    .navbar-brand,.nav-link { color:white !important; font-weight:600; }
    .page-header { background:linear-gradient(135deg,var(--primary),var(--secondary)); color:white; padding:50px 0 70px; text-align:center; position:relative; }
    .page-header::after { content:''; position:absolute; bottom:-2px; left:0; right:0; height:50px; background:#f0f2f5; clip-path:ellipse(55% 100% at 50% 100%); }
    .page-header h1 { font-weight:800; font-size:2.2rem; }
    .content { padding:40px 0 60px; }
    .table-card { background:white; border-radius:16px; box-shadow:0 8px 30px rgba(0,0,0,0.1); overflow:hidden; }
    .table thead { background:linear-gradient(135deg,var(--primary),var(--secondary)); color:white; }
    .table thead th { font-weight:600; padding:14px 16px; border:none; font-size:0.88rem; }
    .table tbody td { padding:13px 16px; font-size:0.88rem; vertical-align:middle; }
    .table tbody tr:hover { background:#f8f7ff; }
    .badge-id { background:#ede9fe; color:#4a00e0; padding:4px 12px; border-radius:20px; font-weight:700; font-size:0.8rem; }

    /* Search box */
    .search-box { background:white; border-radius:12px; padding:16px 20px; box-shadow:0 4px 15px rgba(0,0,0,0.07); margin-bottom:20px; display:flex; gap:12px; align-items:center; flex-wrap:wrap; }
    .search-box input { border:2px solid #e8e8e8; border-radius:8px; padding:9px 14px; font-size:0.9rem; flex:1; min-width:180px; outline:none; transition:border-color 0.3s; }
    .search-box input:focus { border-color:var(--primary); }
    #resultCount { color:#888; font-size:0.85rem; white-space:nowrap; }

    .empty-state { text-align:center; padding:60px 20px; color:#aaa; }
    .empty-state i { font-size:3rem; margin-bottom:15px; display:block; }
    .btn-register { background:linear-gradient(135deg,var(--primary),var(--secondary)); color:white; border:none; border-radius:10px; padding:12px 28px; font-weight:600; text-decoration:none; display:inline-block; margin-top:20px; }
    .btn-register:hover { opacity:0.9; color:white; }
    footer { background:linear-gradient(135deg,var(--primary),var(--secondary)); color:white; text-align:center; padding:20px; font-size:0.88rem; }
    .no-results { text-align:center; padding:30px; color:#aaa; display:none; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/"><i class="bi bi-mortarboard-fill me-2"></i>Cognifyz Academy</a>
      <div class="ms-auto"><a class="nav-link d-inline" href="/"><i class="bi bi-house me-1"></i>Home</a></div>
    </div>
  </nav>

  <div class="page-header">
    <h1><i class="bi bi-people-fill me-2"></i>Registered Students</h1>
    <p class="mt-2" style="opacity:0.9">Total: <strong><%= students.length %></strong> student(s)</p>
  </div>

  <div class="content">
    <div class="container">

      <% if (students.length > 0) { %>
      <!-- Dynamic Search (DOM Manipulation) -->
      <div class="search-box">
        <i class="bi bi-search text-muted"></i>
        <input type="text" id="searchInput" placeholder="Search by name, email or course..."/>
        <span id="resultCount"><%= students.length %> student(s)</span>
      </div>
      <% } %>

      <div class="table-card">
        <% if (students.length === 0) { %>
          <div class="empty-state">
            <i class="bi bi-inbox"></i>
            <h5>No students registered yet</h5>
            <p>Be the first to register!</p>
            <a href="/" class="btn-register">Register Now</a>
          </div>
        <% } else { %>
          <div class="table-responsive">
            <table class="table table-hover mb-0" id="studentsTable">
              <thead>
                <tr>
                  <th>ID</th><th>Name</th><th>Email</th><th>Phone</th>
                  <th>Age</th><th>Gender</th><th>Course</th><th>Registered At</th>
                </tr>
              </thead>
              <tbody id="tableBody">
                <% students.forEach(s => { %>
                  <tr>
                    <td><span class="badge-id">#<%= s.id.toString().padStart(4,'0') %></span></td>
                    <td><strong><%= s.name %></strong></td>
                    <td><%= s.email %></td>
                    <td><%= s.phone %></td>
                    <td><%= s.age %></td>
                    <td><%= s.gender %></td>
                    <td><%= s.course %></td>
                    <td><%= s.registeredAt %></td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
            <div class="no-results" id="noResults"><i class="bi bi-search me-2"></i>No students match your search.</div>
          </div>
        <% } %>
      </div>

      <div class="text-center">
        <a href="/" class="btn-register mt-4"><i class="bi bi-plus-lg me-1"></i>Register New Student</a>
      </div>
    </div>
  </div>

  <footer><p><i class="bi bi-mortarboard-fill me-2"></i>Cognifyz Technologies — Task 4: Dynamic DOM Manipulation</p></footer>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
  <script>
    // Dynamic search — DOM manipulation
    const searchInput = document.getElementById('searchInput');
    if (searchInput) {
      searchInput.addEventListener('input', () => {
        const query = searchInput.value.toLowerCase();
        const rows  = document.querySelectorAll('#tableBody tr');
        let count   = 0;
        rows.forEach(row => {
          const text = row.textContent.toLowerCase();
          const show = text.includes(query);
          row.style.display = show ? '' : 'none';
          if (show) count++;
        });
        document.getElementById('resultCount').textContent = count + ' student(s)';
        document.getElementById('noResults').style.display = count === 0 ? 'block' : 'none';
      });
    }
  </script>
</body>
</html>
