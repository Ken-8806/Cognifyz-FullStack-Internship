<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Dashboard | Cognifyz Task 6</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet"/>
  <style>
    :root { --primary:#667eea; --secondary:#764ba2; }
    body { font-family:'Segoe UI',sans-serif; background:#f0f2f5; }
    .navbar { background:linear-gradient(135deg,var(--primary),var(--secondary)) !important; }
    .navbar-brand,.nav-link { color:white !important; font-weight:600; }
    .hero { background:linear-gradient(135deg,var(--primary),var(--secondary)); color:white; padding:45px 0 65px; position:relative; }
    .hero::after { content:''; position:absolute; bottom:-2px; left:0; right:0; height:50px; background:#f0f2f5; clip-path:ellipse(55% 100% at 50% 100%); }
    .hero h2 { font-weight:800; }
    .content { padding:40px 0 60px; }
    .welcome-card { background:white; border-radius:16px; padding:28px; box-shadow:0 8px 25px rgba(0,0,0,.08); margin-bottom:24px; }
    .welcome-card h4 { font-weight:700; color:#333; }
    .info-pill { background:#ede9fe; color:#4a00e0; padding:5px 14px; border-radius:20px; font-size:.82rem; font-weight:600; display:inline-block; margin:3px; }
    .table-card { background:white; border-radius:16px; box-shadow:0 8px 25px rgba(0,0,0,.08); overflow:hidden; }
    .table-card .table-header { background:linear-gradient(135deg,var(--primary),var(--secondary)); color:white; padding:18px 22px; }
    .table-card .table-header h5 { margin:0; font-weight:700; }
    .table thead th { background:#f8f7ff; color:#555; font-size:.85rem; font-weight:700; padding:12px 16px; border:none; }
    .table tbody td { padding:12px 16px; font-size:.88rem; vertical-align:middle; }
    .table tbody tr:hover { background:#f8f7ff; }
    .badge-user { background:#ede9fe; color:#4a00e0; padding:3px 10px; border-radius:20px; font-size:.75rem; font-weight:700; }
    .you-badge { background:#dcfce7; color:#166534; padding:3px 10px; border-radius:20px; font-size:.75rem; font-weight:700; }
    .btn-logout { background:rgba(255,255,255,.2); border:1px solid rgba(255,255,255,.4); color:white; border-radius:8px; padding:7px 16px; font-size:.85rem; font-weight:600; text-decoration:none; transition:background .2s; }
    .btn-logout:hover { background:rgba(255,255,255,.35); color:white; }
  </style>
</head>
<body>
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand"><i class="bi bi-mortarboard-fill me-2"></i>Cognifyz Task 6</a>
      <div class="ms-auto d-flex align-items-center gap-3">
        <span style="color:rgba(255,255,255,.8); font-size:.9rem"><i class="bi bi-person-circle me-1"></i><%= user.name %></span>
        <a href="/logout" class="btn-logout"><i class="bi bi-box-arrow-right me-1"></i>Logout</a>
      </div>
    </div>
  </nav>

  <div class="hero">
    <div class="container">
      <h2>👋 Welcome, <%= user.name %>!</h2>
      <p style="opacity:.9">You are securely logged in to your Cognifyz dashboard</p>
    </div>
  </div>

  <div class="content">
    <div class="container">
      <div class="welcome-card">
        <h4><i class="bi bi-shield-check me-2" style="color:#667eea"></i>Account Details</h4>
        <div class="mt-3">
          <span class="info-pill"><i class="bi bi-person me-1"></i><%= user.name %></span>
          <span class="info-pill"><i class="bi bi-envelope me-1"></i><%= user.email %></span>
          <span class="info-pill"><i class="bi bi-calendar me-1"></i>Joined: <%= new Date(user.createdAt).toLocaleDateString() %></span>
          <span class="info-pill"><i class="bi bi-database me-1"></i>MongoDB Auth ✅</span>
          <span class="info-pill"><i class="bi bi-lock me-1"></i>bcrypt Encrypted ✅</span>
          <span class="info-pill"><i class="bi bi-key me-1"></i>Session Active ✅</span>
        </div>
      </div>

      <div class="table-card">
        <div class="table-header"><h5><i class="bi bi-people me-2"></i>All Registered Users (<%= users.length %>)</h5></div>
        <div class="table-responsive">
          <table class="table mb-0">
            <thead><tr><th>#</th><th>Name</th><th>Email</th><th>Joined</th><th>Status</th></tr></thead>
            <tbody>
              <% users.forEach((u, i) => { %>
                <tr>
                  <td><span class="badge-user"><%= i+1 %></span></td>
                  <td><strong><%= u.name %></strong></td>
                  <td><%= u.email %></td>
                  <td><%= new Date(u.createdAt).toLocaleDateString() %></td>
                  <td>
                    <% if (u._id.toString() === user._id.toString()) { %>
                      <span class="you-badge">👤 You</span>
                    <% } else { %>
                      <span style="color:#888; font-size:.8rem">Member</span>
                    <% } %>
                  </td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</body>
</html>
