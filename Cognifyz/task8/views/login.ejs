<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Login | Cognifyz Task 6</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet"/>
  <style>
    body { background:linear-gradient(135deg,#667eea,#764ba2); min-height:100vh; display:flex; align-items:center; justify-content:center; font-family:'Segoe UI',sans-serif; padding:20px; }
    .card { border:none; border-radius:18px; box-shadow:0 20px 60px rgba(0,0,0,.2); max-width:420px; width:100%; animation:pop .5s ease; overflow:hidden; }
    .card-header { background:linear-gradient(135deg,#667eea,#764ba2); color:white; text-align:center; padding:32px; border:none; }
    .card-header .icon { font-size:2.8rem; display:block; margin-bottom:8px; }
    .card-header h2 { font-weight:700; margin:0; }
    .card-header p  { opacity:.85; margin:5px 0 0; font-size:.9rem; }
    .card-body { padding:30px; }
    .form-label { font-weight:600; color:#555; font-size:.87rem; }
    .form-control { border:2px solid #e8e8e8; border-radius:10px; padding:11px 14px; transition:border-color .3s; }
    .form-control:focus { border-color:#667eea; box-shadow:0 0 0 3px rgba(102,126,234,.12); }
    .btn-login { background:linear-gradient(135deg,#667eea,#764ba2); color:white; border:none; border-radius:10px; padding:13px; font-weight:700; width:100%; font-size:1rem; transition:opacity .3s; }
    .btn-login:hover { opacity:.9; color:white; }
    .error-box { background:#fff0f0; border:1px solid #ffcccc; border-radius:10px; padding:12px 16px; margin-bottom:18px; color:#cc0000; font-size:.87rem; }
    .link { color:#667eea; font-weight:600; text-decoration:none; }
    .link:hover { text-decoration:underline; }
    @keyframes pop { from{opacity:0;transform:scale(.95)} to{opacity:1;transform:scale(1)} }
  </style>
</head>
<body>
  <div class="card">
    <div class="card-header">
      <span class="icon">🔐</span>
      <h2>Welcome Back!</h2>
      <p>Login to your Cognifyz account</p>
    </div>
    <div class="card-body">
      <% if (error) { %><div class="error-box"><i class="bi bi-exclamation-triangle me-1"></i><%= error %></div><% } %>
      <form action="/login" method="POST" novalidate>
        <div class="mb-3">
          <label class="form-label">Email Address</label>
          <input type="email" name="email" class="form-control" placeholder="your@email.com" required/>
        </div>
        <div class="mb-4">
          <label class="form-label">Password</label>
          <input type="password" name="password" class="form-control" placeholder="Your password" required/>
        </div>
        <button type="submit" class="btn-login"><i class="bi bi-box-arrow-in-right me-2"></i>Login</button>
      </form>
      <p class="text-center mt-4 mb-0" style="font-size:.9rem; color:#888">Don't have an account? <a href="/register" class="link">Register here</a></p>
    </div>
  </div>
</body>
</html>
