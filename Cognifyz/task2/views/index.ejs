<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: linear-gradient(135deg, #667eea, #764ba2);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 30px 20px;
    }
    .card {
      background: #fff;
      border-radius: 16px;
      padding: 40px;
      width: 100%;
      max-width: 520px;
      box-shadow: 0 20px 60px rgba(0,0,0,0.2);
    }
    h1 { text-align: center; color: #4a00e0; margin-bottom: 6px; font-size: 1.8rem; }
    .subtitle { text-align: center; color: #888; margin-bottom: 25px; font-size: 0.9rem; }
    .error-box {
      background: #fff0f0;
      border: 1px solid #ffcccc;
      border-radius: 10px;
      padding: 14px 18px;
      margin-bottom: 20px;
    }
    .error-box p { color: #cc0000; font-size: 0.88rem; margin-bottom: 4px; }
    .error-box p:last-child { margin-bottom: 0; }
    label { display: block; margin-bottom: 5px; color: #555; font-weight: 600; font-size: 0.88rem; }
    input, select {
      width: 100%;
      padding: 11px 14px;
      border: 2px solid #e0e0e0;
      border-radius: 8px;
      font-size: 0.95rem;
      margin-bottom: 5px;
      transition: border-color 0.3s;
      outline: none;
    }
    input:focus, select:focus { border-color: #667eea; }
    .field-error { color: #e00; font-size: 0.8rem; margin-bottom: 12px; display: none; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 0 15px; }
    .radio-group { display: flex; gap: 20px; margin-bottom: 5px; padding: 8px 0; }
    .radio-group label { display: flex; align-items: center; gap: 6px; font-weight: 400; cursor: pointer; color: #444; }
    .radio-group input[type="radio"] { width: auto; margin: 0; accent-color: #667eea; }
    button {
      width: 100%;
      padding: 14px;
      background: linear-gradient(135deg, #667eea, #764ba2);
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 1rem;
      font-weight: 600;
      cursor: pointer;
      margin-top: 10px;
      transition: opacity 0.3s;
    }
    button:hover { opacity: 0.9; }
    .view-link { display: block; text-align: center; margin-top: 15px; color: #667eea; text-decoration: none; font-size: 0.88rem; }
    .view-link:hover { text-decoration: underline; }
    input.invalid, select.invalid { border-color: #e00; }
    input.valid,   select.valid   { border-color: #22c55e; }
  </style>
</head>
<body>
  <div class="card">
    <h1>🎓 Student Registration</h1>
    <p class="subtitle">Fill in all details to register</p>

    <% if (errors && errors.length > 0) { %>
      <div class="error-box">
        <% errors.forEach(err => { %><p>⚠️ <%= err %></p><% }) %>
      </div>
    <% } %>

    <form id="regForm" action="/register" method="POST" novalidate>

      <label for="name">Full Name</label>
      <input type="text" id="name" name="name" placeholder="e.g. Arun Kumar"
        value="<%= old && old.name ? old.name : '' %>" />
      <span class="field-error" id="nameErr">Name must be at least 3 letters only.</span>

      <label for="email">Email Address</label>
      <input type="email" id="email" name="email" placeholder="e.g. arun@email.com"
        value="<%= old && old.email ? old.email : '' %>" />
      <span class="field-error" id="emailErr">Enter a valid email address.</span>

      <div class="row">
        <div>
          <label for="phone">Phone Number</label>
          <input type="text" id="phone" name="phone" placeholder="10 digits" maxlength="10"
            value="<%= old && old.phone ? old.phone : '' %>" />
          <span class="field-error" id="phoneErr">Enter valid 10-digit number.</span>
        </div>
        <div>
          <label for="age">Age</label>
          <input type="number" id="age" name="age" placeholder="15 - 60" min="15" max="60"
            value="<%= old && old.age ? old.age : '' %>" />
          <span class="field-error" id="ageErr">Age must be between 15 and 60.</span>
        </div>
      </div>

      <label for="dob">Date of Birth</label>
      <input type="date" id="dob" name="dob"
        value="<%= old && old.dob ? old.dob : '' %>" />
      <span class="field-error" id="dobErr">Please select your date of birth.</span>

      <label>Gender</label>
      <div class="radio-group">
        <label><input type="radio" name="gender" value="Male"   <%= old && old.gender === 'Male'   ? 'checked' : '' %> /> Male</label>
        <label><input type="radio" name="gender" value="Female" <%= old && old.gender === 'Female' ? 'checked' : '' %> /> Female</label>
        <label><input type="radio" name="gender" value="Other"  <%= old && old.gender === 'Other'  ? 'checked' : '' %> /> Other</label>
      </div>
      <span class="field-error" id="genderErr">Please select a gender.</span>

      <label for="course">Course</label>
      <select id="course" name="course">
        <option value="" disabled <%= !old || !old.course ? 'selected' : '' %>>Select your course</option>
        <option value="B.Tech - Computer Science"       <%= old && old.course === 'B.Tech - Computer Science'       ? 'selected' : '' %>>B.Tech - Computer Science</option>
        <option value="B.Tech - Information Technology" <%= old && old.course === 'B.Tech - Information Technology' ? 'selected' : '' %>>B.Tech - Information Technology</option>
        <option value="B.Sc - Data Science"             <%= old && old.course === 'B.Sc - Data Science'             ? 'selected' : '' %>>B.Sc - Data Science</option>
        <option value="MBA - Technology Management"     <%= old && old.course === 'MBA - Technology Management'     ? 'selected' : '' %>>MBA - Technology Management</option>
        <option value="MCA"                             <%= old && old.course === 'MCA'                             ? 'selected' : '' %>>MCA</option>
      </select>
      <span class="field-error" id="courseErr">Please select a course.</span>

      <button type="submit">Register Now →</button>
    </form>

    <a class="view-link" href="/students">View All Registered Students</a>
  </div>

  <script>
    const form = document.getElementById('regForm');

    function showError(id, show) {
      document.getElementById(id).style.display = show ? 'block' : 'none';
    }
    function markField(el, valid) {
      el.classList.toggle('valid', valid);
      el.classList.toggle('invalid', !valid);
    }

    // Live validation
    const nameEl  = document.getElementById('name');
    const emailEl = document.getElementById('email');
    const phoneEl = document.getElementById('phone');
    const ageEl   = document.getElementById('age');
    const dobEl   = document.getElementById('dob');
    const courseEl= document.getElementById('course');

    nameEl.addEventListener('input', () => {
      const ok = /^[a-zA-Z\s]{3,}$/.test(nameEl.value.trim());
      markField(nameEl, ok); showError('nameErr', !ok);
    });
    emailEl.addEventListener('input', () => {
      const ok = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value);
      markField(emailEl, ok); showError('emailErr', !ok);
    });
    phoneEl.addEventListener('input', () => {
      phoneEl.value = phoneEl.value.replace(/\D/g, '');
      const ok = /^\d{10}$/.test(phoneEl.value);
      markField(phoneEl, ok); showError('phoneErr', !ok);
    });
    ageEl.addEventListener('input', () => {
      const v = parseInt(ageEl.value);
      const ok = v >= 15 && v <= 60;
      markField(ageEl, ok); showError('ageErr', !ok);
    });
    dobEl.addEventListener('change', () => {
      const ok = dobEl.value !== '';
      markField(dobEl, ok); showError('dobErr', !ok);
    });
    courseEl.addEventListener('change', () => {
      const ok = courseEl.value !== '';
      markField(courseEl, ok); showError('courseErr', !ok);
    });

    // Final check on submit
    form.addEventListener('submit', (e) => {
      let valid = true;

      if (!/^[a-zA-Z\s]{3,}$/.test(nameEl.value.trim()))        { showError('nameErr',   true); markField(nameEl,   false); valid = false; }
      if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailEl.value))    { showError('emailErr',  true); markField(emailEl,  false); valid = false; }
      if (!/^\d{10}$/.test(phoneEl.value))                       { showError('phoneErr',  true); markField(phoneEl,  false); valid = false; }
      const age = parseInt(ageEl.value);
      if (!age || age < 15 || age > 60)                          { showError('ageErr',    true); markField(ageEl,    false); valid = false; }
      if (!dobEl.value)                                          { showError('dobErr',    true); markField(dobEl,    false); valid = false; }
      if (!document.querySelector('input[name="gender"]:checked')){ showError('genderErr', true);                            valid = false; }
      else                                                         showError('genderErr', false);
      if (!courseEl.value)                                       { showError('courseErr', true); markField(courseEl, false); valid = false; }
      else                                                       { showError('courseErr', false); markField(courseEl, true); }

      if (!valid) e.preventDefault();
    });
  </script>
</body>
</html>
